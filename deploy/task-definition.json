{
  "_comment": "KPIEE オンボーディング AI — ECS タスク定義テンプレート。<...> を各自の値に置換して登録する。既存クラスタ(DPB と同一)に別サービスとして載せる想定。イメージは GHCR public のため pull 認証不要。",
  "family": "kpiee-onboarding-ai",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/<ecsTaskExecutionRole>",
  "containerDefinitions": [
    {
      "name": "onboarding-ai",
      "image": "ghcr.io/cs-kyoutu/kpiee-onboarding-ai:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "ARTIFACT_EPHEMERAL", "value": "1" },
        { "name": "WEB_DIST", "value": "/app/web/dist" },
        { "name": "DATABASE_URL", "value": "postgres://onboarding:<DB_PASSWORD>@<DPB_RDS_ENDPOINT>:5432/onboarding" },
        { "name": "PGPOOL_MAX", "value": "5" },
        { "name": "ANTHROPIC_API_KEY", "value": "<ANTHROPIC_API_KEY>" },
        { "name": "GOOGLE_OAUTH_CLIENT_ID", "value": "<OAUTH_CLIENT_ID>" },
        { "name": "GOOGLE_OAUTH_CLIENT_SECRET", "value": "<OAUTH_CLIENT_SECRET>" },
        { "name": "GOOGLE_OAUTH_REFRESH_TOKEN", "value": "<REFRESH_TOKEN>" },
        { "name": "GOOGLE_OAUTH_REDIRECT", "value": "https://<APP_HOST>/api/google/callback" },
        { "name": "WEB_APP_ORIGIN", "value": "https://<APP_HOST>" },
        { "name": "CORS_ORIGIN", "value": "https://<APP_HOST>" }
      ],
      "ulimits": [{ "name": "core", "softLimit": 0, "hardLimit": 0 }],
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"fetch('http://localhost:8080/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kpiee-onboarding-ai",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
