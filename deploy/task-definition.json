{
  "_comment": "KPIEE オンボーディング AI — ECS タスク定義（本番用フル構成）。<...> を各自の値に置換して登録する。既存クラスタ(DPB と同一 data-palette-builder)に別サービスとして載せる。イメージは GHCR public のため pull 認証不要。ポートは 8080 で全経路統一（Dockerfile ENV PORT=8080 / containerPort / ヘルスチェック / ターゲットグループ すべて 8080 に一致させること）。DB を有効化する前に、必ず task-definition.smoke.json で /healthz が ALB 経由で healthy になることを先に確認する。",
  "family": "kpiee-onboarding-ai",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::472709934419:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "onboarding-ai",
      "image": "ghcr.io/cs-kyoutu/kpiee-onboarding-ai:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "ARTIFACT_EPHEMERAL", "value": "1" },
        { "name": "WEB_DIST", "value": "/app/web/dist" },
        { "name": "DATABASE_URL", "value": "postgres://onboarding:<DB_PASSWORD>@data-palette-builder-db.cczskye8qhhc.ap-northeast-1.rds.amazonaws.com:5432/onboarding?sslmode=no-verify" },
        { "name": "PGPOOL_MAX", "value": "5" },
        { "name": "ANTHROPIC_API_KEY", "value": "<ANTHROPIC_API_KEY>" },
        { "name": "GOOGLE_OAUTH_CLIENT_ID", "value": "<OAUTH_CLIENT_ID>" },
        { "name": "GOOGLE_OAUTH_CLIENT_SECRET", "value": "<OAUTH_CLIENT_SECRET>" },
        { "name": "GOOGLE_OAUTH_REFRESH_TOKEN", "value": "<REFRESH_TOKEN>" },
        { "name": "GOOGLE_OAUTH_REDIRECT", "value": "https://<APP_HOST>/api/google/callback" },
        { "name": "WEB_APP_ORIGIN", "value": "https://<APP_HOST>" },
        { "name": "CORS_ORIGIN", "value": "https://<APP_HOST>" }
      ],
      "ulimits": [{ "name": "core", "softLimit": 0, "hardLimit": 0 }],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kpiee-onboarding-ai",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
