{
  "_comment": "KPIEE オンボーディング AI — スモーク用タスク定義。DATABASE_URL もシークレットも一切入れない=SQLite(コンテナ内揮発)+mock モードで起動する。狙いは『アプリが起動し /healthz が ALB 経由で 200 を返す』ことだけを、DB・RDS SG・OAuth など他の変数を全部排除して確認すること。これが healthy になってから task-definition.json(フル)へ切り替える。ポートは 8080 で統一。",
  "family": "kpiee-onboarding-ai-smoke",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::472709934419:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "onboarding-ai",
      "image": "ghcr.io/cs-kyoutu/kpiee-onboarding-ai:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "NODE_ENV", "value": "production" }
      ],
      "ulimits": [{ "name": "core", "softLimit": 0, "hardLimit": 0 }],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kpiee-onboarding-ai",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
